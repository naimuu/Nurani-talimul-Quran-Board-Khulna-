generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String?
  phone     String?  @unique
  role      String   @default("GENERAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  madrasaId String?  @db.ObjectId
  madrasa   Madrasa? @relation(fields: [madrasaId], references: [id])
}

model Madrasa {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String
  code        String   @unique
  contactNo   String?
  isApproved  Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notice {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  content   String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageContent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoardSettings {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String?  @default("খুলনা নূরানী তালিমুল কুরআন বোর্ড")
  address    String?
  logoUrl    String?
  coverUrl   String?
  
  contacts   ContactInfo[]
  payments   PaymentMethod[]
  
  updatedAt  DateTime @updatedAt
}

model ContactInfo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  type            String   
  value           String   
  boardSettingsId String   @db.ObjectId
  boardSettings   BoardSettings @relation(fields: [boardSettingsId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  type            String   
  provider        String   
  accountName     String?  
  accountNumber   String   
  branch          String?  
  routingNo       String?  
  boardSettingsId String   @db.ObjectId
  boardSettings   BoardSettings @relation(fields: [boardSettingsId], references: [id], onDelete: Cascade)
}

model Position {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  name       String        @unique
  order      Int           @default(0)
  members    BoardMember[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model BoardMember {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  positionId String   @db.ObjectId
  position   Position @relation(fields: [positionId], references: [id])
  photoUrl   String?
  phone      String?
  type       String   @default("COMMITTEE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
